Options -Indexes
RewriteEngine On

# Pass Authorization header to PHP (Windows Apache)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# IMPORTANT: Route everything (including OPTIONS) to index.php
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [L]